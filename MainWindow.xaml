<Window x:Class="Flarial.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Flarial"
        xmlns:control="clr-namespace:Flarial.Controls"
        mc:Ignorable="d" WindowStyle="None" ResizeMode="NoResize"
        Title="MainWindow" Height="350" Width="550">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" GlassFrameThickness="0" UseAeroCaptionButtons="False" CornerRadius="20"/>
    </WindowChrome.WindowChrome>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition/>
            <RowDefinition Height="40"/>
        </Grid.RowDefinitions>
        <!-- Modal -->
        <ContentControl x:Name="ModalArea"
                        Grid.RowSpan="100"
                        Grid.ColumnSpan="100"
                        Panel.ZIndex="1000"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Width="250"
                        Height="150"/>

        <Grid Grid.RowSpan="100">
            <!-- Drag Bar (Entire window) -->
            <Rectangle x:Name="DragBar" 
                       HorizontalAlignment="Stretch"
                       VerticalAlignment="Stretch"
                       Fill="Transparent"
                       Panel.ZIndex="-1"
                       MouseLeftButtonDown="Rectangle_MouseLeftButtonDown"/>
            <!-- Background -->
            <Image x:Name="bg"
                   Source="/Assets/Images/background.png"
                   VerticalAlignment="Stretch"
                   HorizontalAlignment="Stretch"
                   Stretch="Fill"
                   Panel.ZIndex="-99"/>
            <Rectangle Panel.ZIndex="-98">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#99000000" Offset="0"/>
                        <GradientStop Color="#00000000" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>
        </Grid>
        
        <!-- Title bar grid -->
        <Grid Grid.Row="0">
            <!-- Window Controls -->
            <StackPanel Orientation="Horizontal" 
                        FlowDirection="RightToLeft"
                        Panel.ZIndex="1000">
                <Button x:Name="CloseBtn"
                        Style="{DynamicResource WindowControl}"
                        Content=""
                        HorizontalAlignment="Right"
                        Click="CloseBtn_Click"/>
                <Button x:Name="MinimizeBtn"
                        Style="{DynamicResource WindowControl}"
                        Content=""
                        HorizontalAlignment="Right"
                        Click="MinimizeBtn_Click"/>
            </StackPanel>
            <!-- Title -->
            <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                <Image Source="/Assets/Images/logo.png"
                       Width="50" Margin="10,15,0,10"
                       IsHitTestVisible="False"/>
                <Label Content="Flarial Client"
                       Style="{DynamicResource ResourceKey=Heading}"
                       IsHitTestVisible="False"
                       VerticalContentAlignment="Center"/>

            </StackPanel>
        </Grid>
        <!-- Main Content -->
        <Grid Grid.Row="1">
            <!-- Center Buttons and greeting -->
            <StackPanel Orientation="Vertical"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <TextBlock TextAlignment="Center"
                           Margin="0,0,0,20"
                           IsHitTestVisible="False">
                    <Run Style="{DynamicResource MainGreeting}"
                         Text="Good morning!"
                         x:Name="GreetingMain"/>
                    <LineBreak/>
                    <Run Style="{DynamicResource SecondaryGreeting}"
                         Text="Ready to play?"/>
                </TextBlock>
                <Button Style="{DynamicResource PrimaryButton}"
                        Width="150"
                        x:Name="LaunchBtn"
                        Click="LaunchBtn_Click">
                    <Button.Content>
                        <TextBlock>
                            <Run x:Name="LaunchIcon"
                                 FontFamily="Segoe Fluent Icons"
                                 Text=" "
                                 BaselineAlignment="Center"/>
                            <Run x:Name="LaunchContent" 
                                 Text="Launch"/>
                        </TextBlock>
                    </Button.Content>
                </Button>
                <Button x:Name="SettingsBtn"
                        Style="{DynamicResource SecondaryButton}"
                        Margin="8,5,8,8"
                        Height="38"
                        Width="125"
                        Click="SettingsBtn_Click">
                    <Button.Content>
                        <TextBlock>
                            <Run FontFamily="Segoe Fluent Icons"
                                 Text=" "
                                 BaselineAlignment="Center"/>
                            <Run Text="Options"/>
                        </TextBlock>
                    </Button.Content>
                </Button>


            </StackPanel>

        </Grid>
        <!-- Footer -->
        <Grid Grid.Row="3" IsHitTestVisible="False"
              VerticalAlignment="Center">
            <!-- Disclaimer -->
            <Label Content="Not affiliated with FlarialMC"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Foreground="#80FFFFFF"
                       FontSize="10"
                       Opacity="0.7"
                       FontFamily="{DynamicResource MainFont}"
                       IsHitTestVisible="False"/>
        </Grid>
        <!-- Options border -->
        <Border x:Name="OptionsBorder"
                Grid.RowSpan="100"
                Grid.ColumnSpan="100"
                Panel.ZIndex="100"
                VerticalAlignment="Bottom"
                HorizontalAlignment="Stretch"
                Height="0"
                Margin="10,0,10,0"
                ClipToBounds="True"
                Opacity="0.9">
        </Border>
        <!-- Modal Dim -->
        <Border x:Name="dimwindow"
                Opacity="0"
                Background="Black"
                Grid.ColumnSpan="100"
                Grid.RowSpan="10"
                Panel.ZIndex="97"
                IsHitTestVisible="False"
                MouseDown="dimwindow_MouseDown"/>

    </Grid>
</Window>
