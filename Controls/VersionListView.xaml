<UserControl x:Class="Flarial.Controls.VersionList"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Flarial.Controls"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="400">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <ListBox ItemsSource="{Binding Versions}"
                 SelectedItem="{Binding SelectedVersion, Mode=TwoWay}"
                 Background="Transparent"
                 IsEnabled="{Binding IsNotDownloading}">
            <i:Interaction.Triggers>
                <i:EventTrigger EventName="MouseDoubleClick">
                    <i:InvokeCommandAction Command="{Binding DownloadCommand}"
                                           CommandParameter="{Binding SelectedItem, RelativeSource={RelativeSource AncestorType=ListBox}}"/>
                </i:EventTrigger>
            </i:Interaction.Triggers>

            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Padding="10" Margin="5">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Name}" Foreground="White"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        
        <!-- Progress bar area -->
        <Grid Grid.Row="1" Visibility="{Binding ProgressVisibility}">
            <ProgressBar Panel.ZIndex="-1" Height="30"
                         Minimum="0" Maximum="100"
                         Value="{Binding Progress}"
                         IsIndeterminate="{Binding IsInstalling}"/>
            <TextBlock HorizontalAlignment="Right" IsHitTestVisible="False" VerticalAlignment="Center"
                       Visibility="{Binding DownloadObjectVisible}" Margin="0,0,10,0">
                <Run Style="{DynamicResource SecondaryGreeting}" Text="{Binding DownloadedSize}" />
                <Run Style="{DynamicResource SecondaryGreeting}" Text="/" />
                <Run Style="{DynamicResource SecondaryGreeting}" Text="{Binding DownloadSize}" />
                <Run Style="{DynamicResource SecondaryGreeting}" Text="GB" />
            </TextBlock>


            <TextBlock HorizontalAlignment="Left" IsHitTestVisible="False" VerticalAlignment="Center" Margin="10,0,0,0">
                <Run Style="{DynamicResource SecondaryGreeting}" Text="{Binding Status, Mode=OneWay}"/>
            </TextBlock>
        </Grid>
    </Grid>
</UserControl>
