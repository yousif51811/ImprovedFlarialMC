<UserControl x:Class="Flarial.Controls.ModalMessage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Flarial.Controls"
             mc:Ignorable="d" ClipToBounds="True"
             d:DesignHeight="150" d:DesignWidth="250">
    <Border CornerRadius="20" ClipToBounds="True" Background="#1c1513">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="35"/>
                <RowDefinition/>
                <RowDefinition Height="40"/>
            </Grid.RowDefinitions>
            
            <!-- Title label -->
            <Label Content="{Binding Title}"
                   Style="{DynamicResource Heading}"
                   FontSize="16"/>
            <!-- Message textblock-->
            <ScrollViewer Grid.Row="1">
                <TextBlock
                       Text="{Binding Message}"
                       FontSize="12"
                       FontWeight="Medium"
                       Margin="10"
                       TextWrapping="Wrap"
                       FontFamily="{DynamicResource MainFont}"
                       Foreground="White"/>
            </ScrollViewer>
            <!-- Buttons -->
            <Button Grid.Row="2"
                    Content="OK"
                    Style="{DynamicResource PrimaryButton}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="14"
                    Padding="15,5"
                    Click="Button_Click"/>

            <!-- Copy button -->
            <Button Grid.Row="1"
                    Style="{DynamicResource WindowControl}"
                    Content=""
                    VerticalAlignment="Bottom"
                    HorizontalAlignment="Right"
                    Margin="5"
                    Width="30"
                    FontSize="12"
                    Height="30"
                    Click="Copy_Click"/>
        </Grid>
    </Border>
</UserControl>
